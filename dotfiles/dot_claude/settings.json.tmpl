{
  "model": "{{ or (index . "model") "claude-sonnet-4-6" }}",
  "theme": "{{ or (index . "theme") "dark" }}",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dcg"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "AWS_REGION": "us-east-1",
    "AWS_PROFILE": "hc-devopstooling-prod"
  }
}
